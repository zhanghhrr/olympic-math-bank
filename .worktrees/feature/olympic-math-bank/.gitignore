# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# database
*.db
*.db-journal
# but keep dev.db for demonstration
!lib/db/dev.db
!lib/db/*.db

# OCR uploads (runtime data)
/uploads/

# Test outputs
/test-output/

# Logs
*.log

# Static demo prototypes (not part of Next.js app)
/static-demo/

# One-off migration/utility scripts
/migrate-data.mjs
/check-data.mjs
/check-db.mjs
/add-user.mjs

# Temp test files at root
/test-*.ts
/test-*.js
/test-*.mjs

# Misc root artifacts
/ai-project-charter-workflow.zip
/claude-code.bat
/simpletex-test-output.md
/verify_general_lecture.py
