# ============================================
# 奥林匹克数学题库管理系统 - 环境变量配置
# 复制此文件为 .env 或 .env.local 后修改
# ============================================

# ---- 数据库 ----
# 本地开发（SQLite）:
# DATABASE_URL="file:./dev.db"
#
# 生产环境（PostgreSQL / Docker Compose）:
DATABASE_URL="postgresql://postgres:postgres@postgres:5432/olympic_math"
#
# 注意：使用 PostgreSQL 时需将 lib/db/schema.prisma 中 provider 改为 "postgresql"

# ---- NextAuth.js 认证 ----
# 生产环境必须设置（用于 JWT 签名，生成命令：openssl rand -base64 32）
NEXTAUTH_SECRET="change-me-to-a-random-string-at-least-32-chars"
NEXTAUTH_URL="http://localhost:3000"

# ---- AI 辅助标签（可选）----
# 用于自动打标签、公式识别、知识标注
OPENAI_API_KEY="sk-your-openai-api-key"

# ---- OCR 配置（可选）----
# MinerU API 地址（主 OCR 引擎，如需使用请配置）
MINERU_API_URL=""
MINERU_API_KEY=""

# ---- 文件上传 ----
# 上传文件存储路径（默认项目根目录 /uploads）
UPLOAD_DIR="./uploads"
# 最大上传文件大小（字节，默认 50MB）
MAX_UPLOAD_SIZE=52428800
