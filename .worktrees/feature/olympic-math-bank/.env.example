# ============================================================
# 奥林匹克数学题库管理系统 - 环境变量配置参考
# 复制此文件为 .env 并填入实际值
# ============================================================

# MinerU API Token（OCR 识别服务，必需）
# 获取地址: https://mineru.net/apiManage/docs
MINERU_API_TOKEN=your-mineru-api-token-here

# 数据库连接
# 开发环境（SQLite）:
DATABASE_URL="file:./dev.db"
# 生产环境（PostgreSQL）:
# DATABASE_URL="postgresql://user:password@localhost:5432/olympic_math_bank"

# NextAuth 配置
NEXTAUTH_SECRET=your-secret-key-here
NEXTAUTH_URL=http://localhost:3000

# 应用 URL（MinerU 回调/公开文件访问）
NEXT_PUBLIC_APP_URL=http://localhost:3000

# OpenAI API Key（AI 自动打标签，可选）
# OPENAI_API_KEY=sk-xxx
