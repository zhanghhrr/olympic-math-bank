generator client {
  provider = "prisma-client-js"
}

// 数据库数据源配置
//   本地开发: provider = "sqlite",   DATABASE_URL="file:./dev.db"（.env.local 中配置）
//   Docker 部署: provider 自动切换为 "postgresql"（Dockerfile 中 sed 替换）
//   无需手动修改，Docker 构建时自动处理
datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// 用户角色
enum UserRole {
  ADMIN
  REVIEWER
  EDITOR
}

// 题目类型 - 限定为四类
enum QuestionType {
  FILL_BLANK       // 填空题
  CHOICE           // 选择题（包含单选和多选）
  SOLUTION         // 解答题
  CALCULATION      // 计算题
}

// 题目状态
enum QuestionStatus {
  DRAFT     // 草稿
  PENDING   // 待审核
  APPROVED  // 已通过
  REJECTED  // 已拒绝
}

// 年级
enum Grade {
  P1  // 小学一年级
  P2  // 小学二年级
  P3  // 小学三年级
  P4  // 小学四年级
  P5  // 小学五年级
  P6  // 小学六年级
}

// 标签类型
enum TagType {
  GRADE       // 年级
  DIFFICULTY  // 难度
  KNOWLEDGE   // 知识点（四级）
  COMPETITION // 竞赛类型
}

// 导入任务状态
enum ImportStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

// 用户表
model User {
  id            String    @id @default(uuid())
  phone         String    @unique  // 手机号，登录唯一标识
  name          String
  role          UserRole  @default(EDITOR)
  password      String?   // 可选，支持 OAuth
  email         String?   // 邮箱（可选）
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // 关联
  questions     Question[]
  reviews       Review[]
  importJobs    ImportJob[]
  exportJobs    ExportJob[]
  versions      QuestionVersion[]

  @@map("users")
}

// 题目表
model Question {
  id              String          @id @default(uuid())
  content         String
  answer          String
  solution        String?
  type            QuestionType
  options         String?         // JSON string for SQLite
  grade           Grade
  difficulty      Int
  source          String?         // 题目来源
  year            Int?            // 年份
  competition     String?         // 竞赛类型
  status          QuestionStatus  @default(DRAFT)
  formulas        String?         // JSON: [{latex, bbox, page, verifyStatus}] 公式列表
  sourceBlocks    String?         // JSON: [{type, text, bbox, pageIdx}] 原始OCR Block
  sourcePdfName   String?         // 来源PDF文件名（用于公式比对截图定位原文件）
  
  // 外键
  createdById     String
  createdBy       User            @relation(fields: [createdById], references: [id])
  currentVersionId String?        @unique
  knowledgeTagId  String?         // 唯一知识标签（五级叶子节点），一道题只能有一个
  knowledgeTag    KnowledgeTag?   @relation(fields: [knowledgeTagId], references: [id], onDelete: SetNull)
  
  // 关联
  images          QuestionImage[]
  tags            QuestionTag[]
  reviews         Review[]
  versions        QuestionVersion[]
  importItems     ImportJobItem[]
  
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@map("questions")
}

// 题目版本表
model QuestionVersion {
  id          String    @id @default(uuid())
  questionId  String
  question    Question  @relation(fields: [questionId], references: [id], onDelete: Cascade)
  version     Int
  content     String
  answer      String
  solution    String?
  options     String?   // JSON string for SQLite
  formulas    String?   // JSON: 公式列表快照
  sourceBlocks String?  // JSON: OCR Block 快照
  changeLog   String    // 修改说明
  createdById String
  createdBy   User      @relation(fields: [createdById], references: [id])
  createdAt   DateTime  @default(now())

  @@unique([questionId, version])
  @@map("question_versions")
}

// 题目图片表
model QuestionImage {
  id              String    @id @default(uuid())
  questionId      String?
  question        Question? @relation(fields: [questionId], references: [id], onDelete: SetNull)
  url             String    // 文件路径
  ocrText         String?
  ocrConfidence   Float?
  order           Int       @default(0)
  status          ImportStatus @default(PENDING)
  createdAt       DateTime  @default(now())

  @@map("question_images")
}

// 标签表
model Tag {
  id          String    @id @default(uuid())
  name        String    @unique
  type        TagType
  parentId    String?
  parent      Tag?      @relation("TagHierarchy", fields: [parentId], references: [id])
  children    Tag[]     @relation("TagHierarchy")
  description String?
  order       Int       @default(0)
  
  // 关联
  questions   QuestionTag[]
  
  createdAt   DateTime  @default(now())

  @@map("tags")
}

// 题目标签关联表
model QuestionTag {
  questionId  String
  question    Question  @relation(fields: [questionId], references: [id], onDelete: Cascade)
  tagId       String
  tag         Tag       @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([questionId, tagId])
  @@map("question_tags")
}

// 审核表
model Review {
  id          String          @id @default(uuid())
  questionId  String
  question    Question        @relation(fields: [questionId], references: [id], onDelete: Cascade)
  reviewerId  String
  reviewer    User            @relation(fields: [reviewerId], references: [id])
  status      QuestionStatus  // APPROVED or REJECTED
  comment     String?
  createdAt   DateTime        @default(now())

  @@map("reviews")
}

// 导入任务表
model ImportJob {
  id              String          @id @default(uuid())
  type            String          // IMAGE or PDF
  fileUrl         String
  fileName        String
  status          ImportStatus    @default(PENDING)
  totalItems      Int             @default(0)
  processedItems  Int             @default(0)
  failedItems     Int             @default(0)
  errorMessage    String?
  createdById     String
  createdBy       User            @relation(fields: [createdById], references: [id])
  
  // 关联
  items           ImportJobItem[]
  
  createdAt       DateTime        @default(now())
  completedAt     DateTime?

  @@map("import_jobs")
}

// PDF 导出任务表（异步轮询模式，仿教研云方案）
model ExportJob {
  id              String       @id @default(uuid())
  fileName        String                        // 导出文件名，如 "exam_20250101.pdf"
  filePath        String?                       // 服务器上 PDF 文件路径（COMPLETED 时有值）
  fileSize        Int?                          // 文件大小（字节）
  status          ImportStatus @default(PENDING) // PENDING|PROCESSING|COMPLETED|FAILED
  mode            String       @default("student") // "student"|"teacher"
  questionCount   Int          @default(0)      // 包含题目数
  error           String?                       // 失败原因
  blocksJson      String?                       // JSON: 前端 blocks 原始数据（用于重试）
  createdById     String
  createdBy       User         @relation(fields: [createdById], references: [id])
  createdAt       DateTime     @default(now())
  completedAt     DateTime?

  @@map("export_jobs")
}

// 导入任务项表
model ImportJobItem {
  id              String          @id @default(uuid())
  jobId           String
  job             ImportJob       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  imageUrl        String
  ocrResult       String?         // JSON string for SQLite
  parsedData      String?         // JSON string for SQLite
  status          ImportStatus    @default(PENDING)
  questionId      String?
  question        Question?       @relation(fields: [questionId], references: [id])
  errorMessage    String?
  createdAt       DateTime        @default(now())

  @@map("import_job_items")
}

// 五级知识标签表
model KnowledgeTag {
  id              String          @id @default(uuid())
  level           Int             // 1-5 级
  name            String          // 标签名称
  code            String          @unique  // 唯一编码，如 "计算模块-整数-整数加减-整数加法运算-加法横式"
  
  // 标签树命名空间："default"=系统五级知识树, "散测入学"=散测题库两级标签, ...完全隔离
  namespace       String          @default("default") // 标签树命名空间

  // 五级层级关系
  module          String          // 一级：模块（如：计算模块、几何模块）
  topic           String?         // 二级：专题（如：整数、小数、分数）
  subtopic        String?         // 三级：子专题（如：整数加减、整数乘除）
  knowledge       String?         // 四级：知识点（如：整数加法运算）
  skill           String?         // 五级：技能（如：加法横式、加法竖式）

  // 父子关系（可选，用于快速查询）
  parentId        String?
  parent          KnowledgeTag?   @relation("KnowledgeHierarchy", fields: [parentId], references: [id])
  children        KnowledgeTag[]  @relation("KnowledgeHierarchy")

  // 排序
  order           Int             @default(0)

  // 关联（反向：标签被哪些题目引用）
  questions       Question[]

  createdAt       DateTime        @default(now())

  @@index([namespace])
  @@index([module])
  @@index([level])
  @@index([code])
  @@map("knowledge_tags")
}
